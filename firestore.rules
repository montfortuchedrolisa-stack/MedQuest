rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - username: string (required) - User chosen username
    //   - email: string (required) - User email
    //   - createdAt: string (required) - Account creation timestamp
    //   - trialStartDate: string (required) - Start date of the 3-day trial
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email', 'createdAt', 'trialStartDate']) &&
             data.uid is string &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             data.email is string &&
             data.createdAt is string &&
             data.trialStartDate is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;
    }
  }
}
